# Copy this file to ".env" and fill in your own values.
# .env is gitignored so your credentials never get committed.

# ---- MongoDB connection string ----
# Local MongoDB:
#   MONGODB_URI=mongodb://127.0.0.1:27017/devhunt
# MongoDB Atlas (cloud) — get this from Atlas > Connect > Drivers:
#   MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/devhunt?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/devhunt

# Port the server listens on
PORT=4000

# Comma-separated list of allowed CORS origins. Use * to allow all (dev only).
# Example: CORS_ORIGIN=http://localhost:4000,https://myapp.example.com
CORS_ORIGIN=*
